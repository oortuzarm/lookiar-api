# ─── Database ───────────────────────────────────────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/lookiar?schema=public
# Railway: Railway lo inyecta automáticamente como DATABASE_URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lookiar?schema=public"

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Generá uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── AWS S3 ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="sa-east-1"
AWS_BUCKET="lookiar-assets"
# Opcional: URL de CloudFront CDN (si no se configura, se usa la URL directa de S3)
AWS_CLOUDFRONT_URL=""

# ─── CORS ───────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma
# En producción: tu dominio de Vercel + dominios personalizados
CORS_ORIGINS="http://localhost:3001,https://tu-dashboard.vercel.app"

# ─── App ────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
